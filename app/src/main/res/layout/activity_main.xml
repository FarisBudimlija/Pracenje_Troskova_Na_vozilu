<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Praćenje Troškova i Servisa"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="15dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:padding="12dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔 STATUS SERVISNOG INTERVALA:"
                android:textStyle="bold"
                android:textColor="#C62828"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/txtServiceStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Unesite podatke o zadnjem servisu i trenutne kilometre za proračun."
                android:textSize="15sp"
                android:textColor="#222222"
                android:layout_marginTop="5dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⛽ UNOS GORIVA"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/inputFuelPrice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Cijena goriva (KM)"
            android:inputType="numberDecimal"
            android:background="@android:drawable/editbox_background_normal"
            android:padding="10dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/inputFuelLiters"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Količina goriva (Litar)"
            android:inputType="numberDecimal"
            android:background="@android:drawable/editbox_background_normal"
            android:padding="10dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/inputCurrentKM"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Trenutna kilometraža vozila (km)"
            android:inputType="number"
            android:background="@android:drawable/editbox_background_normal"
            android:padding="10dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔧 UNOS ZADNJEG SERVISA"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/inputServicePrice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Cijena servisa (KM)"
            android:inputType="numberDecimal"
            android:background="@android:drawable/editbox_background_normal"
            android:padding="10dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/inputServiceKM"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Urađen na kilometraži (km)"
            android:inputType="number"
            android:background="@android:drawable/editbox_background_normal"
            android:padding="10dp"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Izračunaj i Ažuriraj Podatke"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 ZADNJI FINANSIJSKI UNOS"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:layout_marginBottom="5dp"/>

        <TextView
            android:id="@+id/txtHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trenutno nema finansijskih troškova."
            android:textSize="14sp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:padding="12dp"
            android:textColor="#444444"
            android:layout_marginBottom="25dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Odjavi se"
            android:backgroundTint="#C62828"
            android:textColor="#FFFFFF"
            android:layout_gravity="center_horizontal"/>

    </LinearLayout>
</ScrollView>